<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IP Geolocation & Mapify</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <div class="container">
        <h1>Where am I ??</h1>

        <div class="find-me">
            <form action="/find-me" method="POST">
                <button type="submit" class="find-me">Find my location</button>
            </form>
        </div>

        <div class="find-them">
            <h3>Search IP</h3>
            <form action="/find-me" method="POST">
                <label for="ipAddress">Enter IPv4 or IPv6 Address:</label>
                <input 
                    type="text" 
                    id="ipAddress" 
                    name="customIp" 
                    placeholder="e.g., 8.8.8.8 or 2401:4900:..."
                    value="<%= locals.data?.searchedIp ? data.searchedIp : '' %>"
                    required
                >
                <button type="submit" class="find-me">Search IP</button>
            </form>
        </div>

        <% if (locals.data?.countryCode) { %>
            <hr>
            
            <div class="info">
                <h2>Location Detected!</h2>
                <p><strong>Country code:</strong> <%= data.countryCode %></p>
                <p><strong>IP Address Looked Up:</strong> <%= data.userIp %></p>
            </div>

            <form action="/map-me" method="POST">
                <input type="hidden" name="lat" value="<%= data.lat %>">
                <input type="hidden" name="lon" value="<%= data.lon %>">
                <input type="hidden" name="countryCode" value="<%= data.countryCode %>">
                <input type="hidden" name="userIp" value="<%= data.userIp %>">

                <button type="submit" class="map-me">Mapify</button>
            </form>
        <% } %>

        <% if (locals.data?.mapUrl) { %>
            <div class="map-box">
                <h3>Your Map Location:</h3>
                <div class="map-wrapper">
                    <iframe src="<%= data.mapUrl %>"></iframe>
                </div>
            </div>
        <% } %>
    </div>
    
</body>
</html>